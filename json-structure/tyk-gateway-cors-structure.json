{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "CORS",
  "type": "object",
  "properties": {
    "allowCredentials": {
      "type": "boolean"
    },
    "allowedHeaders": {
      "type": "array"
    },
    "allowedMethods": {
      "type": "array"
    },
    "allowedOrigins": {
      "type": "array"
    },
    "debug": {
      "type": "boolean"
    },
    "enabled": {
      "type": "boolean"
    },
    "exposedHeaders": {
      "type": "array"
    },
    "maxAge": {
      "type": "integer"
    },
    "optionsPassthrough": {
      "type": "boolean"
    }
  }
}