{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "Cache",
  "type": "object",
  "properties": {
    "cacheAllSafeRequests": {
      "type": "boolean"
    },
    "cacheByHeaders": {
      "type": "array"
    },
    "cacheResponseCodes": {
      "type": "array"
    },
    "controlTTLHeaderName": {
      "type": "string"
    },
    "enableUpstreamCacheControl": {
      "type": "boolean"
    },
