{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Policy",
  "type": "object",
  "properties": {
    "_id": {
      "type": "string"
    },
    "access_rights": {
      "type": "object"
    },
    "active": {
      "type": "boolean"
    },
    "enable_http_signature_validation": {
      "type": "boolean"
    },
    "graphql_access_rights": {
      "type": "object"
    },
    "hmac_enabled": {
      "type": "boolean"
    },
    "id": {
      "type": "string"
    },
    "is_inactive": {
      "type": "boolean"
    },
    "key_expires_in": {
