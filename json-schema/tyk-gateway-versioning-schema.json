{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Versioning",
  "type": "object",
  "properties": {
    "default": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean"
    },
    "fallbackToDefault": {
      "type": "boolean"
    },
    "key": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "stripVersioningData": {
      "type": "boolean"
    },
    "urlVersioningPattern": {
      "type": "string"
    },
    "versions": {
      "type": "array"
    }
  }
}