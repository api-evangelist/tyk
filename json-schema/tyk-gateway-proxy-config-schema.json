{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProxyConfig",
  "type": "object",
  "properties": {
    "check_host_against_uptime_tests": {
      "type": "boolean"
    },
    "disable_strip_slash": {
      "type": "boolean"
    },
    "enable_load_balancing": {
      "type": "boolean"
    },
    "listen_path": {
      "type": "string"
    },
    "preserve_host_header": {
      "type": "boolean"
    },
    "strip_listen_path": {
      "type": "boolean"
    },
    "target_list": {
      "type": "array"
    },
    "target_url": {
      "type": "string"
    },
    "transport": {
      "type": "object"
    }
  }
}